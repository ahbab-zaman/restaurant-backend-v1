PORT=8000
NODE_ENV=development
APP_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

DATABASE_URL=postgresql://username:password@localhost:5432/database_name

# Legacy JWT keys retained temporarily during the migration.
# Remove them once the custom JWT flow is fully deleted from the codebase.
JWT_SECRET=your_jwt_secret_here
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here

# Better Auth
BETTER_AUTH_SECRET=your_better_auth_secret_here
BETTER_AUTH_URL=http://localhost:8000

# Google OAuth via Better Auth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/callback/google

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here
EMAIL_FROM=noreply@yourapp.com

# Stripe
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Video provider
VIDEO_PROVIDER=cloudflare-stream
VIDEO_SIGNING_SECRET=your_video_signing_secret

# Database seed credentials
# Used only by prisma/seed.ts via `npm run db:seed`
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=your_admin_password_here
SEED_INSTRUCTOR_EMAIL=instructor@example.com
SEED_INSTRUCTOR_PASSWORD=your_instructor_password_here
