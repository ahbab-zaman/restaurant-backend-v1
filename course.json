    {
      "name": "Auth",
      "description": "Current auth routes. Use OTP registration under /api/v1/auth, then Better Auth sign-in under /api/auth for protected course-platform endpoints.",
      "item": [
        {
          "name": "Auth - Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Register a new student account through the OTP signup flow.\n\nValidation:\n- name: min 2 characters\n- email: valid email\n- password: min 6 characters\n- phone: optional\n\nAfter this request, use Auth - Verify Email.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Student Demo\",\n  \"email\": \"student@example.com\",\n  \"password\": \"StrongPassword123!\",\n  \"phone\": \"+8801700000000\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}{{apiPrefix}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "{{apiPrefix}}",
                "auth",
                "register"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Auth - Verify Email",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Verify signup email with the 6-digit OTP sent by email.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student@example.com\",\n  \"otp\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}{{apiPrefix}}/auth/verify-email",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "{{apiPrefix}}",
                "auth",
                "verify-email"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Auth - Resend Verification OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Resend the signup verification OTP.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student@example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}{{apiPrefix}}/auth/resend-verification",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "{{apiPrefix}}",
                "auth",
                "resend-verification"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Auth - Better Auth Sign In",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Recommended sign-in route for protected business APIs. This creates the Better Auth session cookie used by authorize() middleware.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student@example.com\",\n  \"password\": \"StrongPassword123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}{{apiPrefix}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "sign-in",
                "email"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Auth - Better Auth Get Session",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  const sessionUserId = body?.user?.id || body?.session?.userId;",
                  "  if (sessionUserId) pm.collectionVariables.set('userId', sessionUserId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "description": "Inspect the current Better Auth session after sign-in.",
            "url": {
              "raw": "{{baseUrl}}{{apiPrefix}}/auth/get-session",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "get-session"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Auth - Better Auth Sign Out",
          "request": {
            "method": "POST",
            "header": [],
            "description": "Terminate the current Better Auth session.",
            "url": {
              "raw": "{{baseUrl}}{{apiPrefix}}/auth/logout",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "sign-out"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Auth - Legacy Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  const payload = body?.data || {};",
                  "  const user = payload.user;",
                  "  if (user?.id) pm.collectionVariables.set('userId', user.id);",
                  "  if (payload.accessToken) pm.collectionVariables.set('accessToken', payload.accessToken);",
                  "  if (payload.refreshToken) pm.collectionVariables.set('refreshToken', payload.refreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Legacy token login route under /api/v1/auth.\n\nThis now returns `accessToken` and `refreshToken` in the response body and the collection saves them into collection variables automatically. The active authorization middleware also accepts `Authorization: Bearer {{accessToken}}`, so you do not need to paste tokens manually after this request.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student@example.com\",\n  \"password\": \"StrongPassword123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}{{apiPrefix}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "{{apiPrefix}}",
                "auth",
                "login"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Auth - Legacy Refresh Token",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const refreshToken = pm.collectionVariables.get('refreshToken');",
                  "if (refreshToken) {",
                  "  pm.cookies.jar().set(pm.request.url, 'refreshToken', refreshToken, function () {});",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  const payload = body?.data || {};",
                  "  if (payload.accessToken) pm.collectionVariables.set('accessToken', payload.accessToken);",
                  "  if (payload.refreshToken) pm.collectionVariables.set('refreshToken', payload.refreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "description": "Legacy refresh route. Uses the stored `refreshToken` variable to refresh tokens automatically and then updates the collection variables.",
            "url": {
              "raw": "{{baseUrl}}{{apiPrefix}}/auth/refresh",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "{{apiPrefix}}",
                "auth",
                "refresh"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Auth - Legacy Logout",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const refreshToken = pm.collectionVariables.get('refreshToken');",
                  "if (refreshToken) {",
                  "  pm.cookies.jar().set(pm.request.url, 'refreshToken', refreshToken, function () {});",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  pm.collectionVariables.unset('accessToken');",
                  "  pm.collectionVariables.unset('refreshToken');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "description": "Legacy logout route for the custom token flow. On success, the collection clears `accessToken` and `refreshToken` automatically.",
            "url": {
              "raw": "{{baseUrl}}{{apiPrefix}}/auth/logout",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "{{apiPrefix}}",
                "auth",
                "logout"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Auth - Compatibility Dashboard",
          "request": {
            "method": "GET",
            "header": [],
            "description": "Legacy success page route still mounted under /api/v1/auth/dashboard.",
            "url": {
              "raw": "{{baseUrl}}{{apiPrefix}}/auth/dashboard",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "{{apiPrefix}}",
                "auth",
                "dashboard"
              ]
            }
          },
          "response": []
        }
      ]
    },
